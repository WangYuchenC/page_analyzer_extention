{
  "name": "page-analyzer-extension",
  "displayName": "Page Analyzer - LLM 辅助爬虫",
  "version": "0.0.1",
  "description": "通过 LLM 辅助分析页面结构，生成爬虫代码",
  "author": "WangYuchenC@github.com",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.7",
    "autoprefixer": "10.5.0",
    "langchain": "^1.4.2",
    "lucide-react": "0.400.0",
    "openai": "4.52.0",
    "plasmo": "0.90.5",
    "postcss": "8.5.15",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.4",
    "zod": "^4.4.3",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.268",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "scripting",
      "storage",
      "debugger",
      "sidePanel",
      "tabs"
    ],
    "host_permissions": [
      "https://*/*",
      "http://*/*"
    ]
  }
}
